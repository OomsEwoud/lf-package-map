  },
  "author": "Ewoud Ooms",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OomsEwoud/lf-package-map.git"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "main": "dist/index.js",
  "license": "MIT",
  "devDependencies": {
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-leaflet": "^4.0.0",
    "leaflet": "^1.9.0"
  },
  "scripts": {
    "build": "tsc",
    "ci": "npm run build && npm run check-format && npm run test",
